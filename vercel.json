{
  "version": 2,
  "buildCommand": "npm run build && npm run build:vercel",
  "outputDirectory": "public",
  "installCommand": "npm install",
  "framework": null,
  "crons": [
    {
      "path": "/api/rates/sync-scheduled",
      "schedule": "*/1 * * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/[...path]" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
