# Copy this file to .env and fill in your values.

# Server configuration
PORT=3000

# PostgreSQL database connection string
# Examples:
#   - Local Postgres:
#     postgres://postgres:password@127.0.0.1:5432/ratedisplay
#   - Remote Postgres:
#     postgres://USER:PASS@HOST:5432/DB
DATABASE_URL=

# Client configuration (used at build time)
# For local development:
VITE_API_BASE_URL=http://localhost:3000

# If you host the UI under a sub-path (example: https://www.devi-jewellers.com/displayrates)
VITE_BASE_PATH=/

# For production you might set:
# VITE_API_BASE_URL=https://www.devi-jewellers.com/displayrates
# VITE_BASE_PATH=/displayrates/